[Unit]
Description=Ollama profile %i
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
EnvironmentFile=%h/.local/state/remote-ollama/systemd/%i.env
ExecStart=/usr/bin/env ollama serve
Restart=on-failure
RestartSec=3
WorkingDirectory=%h

[Install]
WantedBy=default.target
