# Copy to config/llm-host.env and edit locally. Do not commit secrets.

LLM_REMOTE_USER=darren
LLM_INTERNAL_HOST=192.168.1.143
LLM_EXTERNAL_HOST=207.6.34.73
LLM_SSH_PORT=2222
LLM_SSH_KEY=~/.ssh/ubuntu_llm_ed25519
LLM_SSH_CONNECT_TIMEOUT=10

# SSH host alias from ~/.ssh/config. When set, the tooling can use this alias
# instead of constructing SSH args from LLM_*_HOST + LLM_SSH_PORT + LLM_SSH_KEY.
# Defined aliases: "llm-lan" (internal LAN), "llm-vpn" (external/VPN).
LLM_SSH_HOST_ALIAS=llm-vpn

LLM_DEFAULT_ROUTE=external
LLM_REMOTE_PROJECT_DIR=/home/darren/Documents/GitHub/agent-kernel
LLM_REMOTE_SCRIPTS_DIR=/home/darren/bin
LLM_REMOTE_PACKAGE_DIR=/home/darren/remote-ollama-control
LLM_REMOTE_PROFILE_CMD=/home/darren/bin/remote-ollama-profile

# Safe default is loopback-only. Set to 0.0.0.0 or a LAN/VPN interface only
# after firewalling the host or when access is otherwise controlled.
LLM_OLLAMA_BIND_HOST=127.0.0.1

# Optional local result directory on the Mac.
LLM_RESULTS_DIR=./results

# Vault directory containing the 50 content-gen benchmark scenarios.
# Defaults to ~/Documents/Obsidian/agent-kernel-vault on macOS.
# LLM_AK_VAULT_DIR=~/Documents/Obsidian/agent-kernel-vault

# Remote manager mode: auto, pid, systemd-user, or systemd-system.
LLM_PROFILE_MANAGER=auto
