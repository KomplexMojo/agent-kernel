# Copy to config/ufw.env on the Ubuntu LLM host and edit before running.

# SSH access to the Ubuntu LLM host.
UFW_SSH_PORT=2222
UFW_SSH_SOURCES="192.168.1.0/24"

# Ollama profile ports:
#   primary   11434
#   secondary 11435
#   dual      11436
#
# Keep this restricted to your Mac LAN IP, VPN subnet, or trusted admin subnet.
# Do not use 0.0.0.0/0 for Ollama.
UFW_OLLAMA_PORTS="11434,11435,11436"
UFW_OLLAMA_SOURCES="192.168.1.0/24"

# Optional admin services. Leave empty unless needed.
UFW_EXTRA_TCP_RULES=""

# Set to 1 to allow outbound traffic. Most Ubuntu desktops/servers need this.
UFW_ALLOW_OUTGOING=1
